NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/elysia_auth_template

# Authentication
GOOGLE_CLIENT_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL=auth@example.com
RESEND_FROM_NAME=Auth Template
EMAIL_VERIFICATION_TTL_SECONDS=86400
SESSION_SECRET=change-me-to-a-long-random-secret
SESSION_ISSUER=elysia-auth-template
SESSION_COOKIE_NAME=auth_template_session
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_SECONDS=604800

# App security
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TRUST_PROXY_HEADERS=false
MAX_REQUEST_BODY_SIZE_BYTES=65536

# Rate limiting
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_ACCOUNT_PER_MINUTE=60
