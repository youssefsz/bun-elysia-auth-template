NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/tricky_genie

# Authentication
APP_PUBLIC_URL=http://localhost:3000
FRONTEND_PUBLIC_URL=http://localhost:5173
AUTH_EMAIL_RESEND_COOLDOWN_SECONDS=60
AUTH_EMAIL_MAX_PER_HOUR=5
AUTH_EMAIL_MAX_PER_DAY=10
EMAIL_VERIFICATION_FRONTEND_PATH=/verify-email
PASSWORD_RESET_FRONTEND_PATH=/reset-password
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_IDS=tn.youssef.genie
APPLE_APP_STORE_BUNDLE_ID=tn.youssef.genie
APPLE_APP_STORE_APP_ID=
APPLE_APP_STORE_ISSUER_ID=
APPLE_APP_STORE_KEY_ID=
APPLE_APP_STORE_PRIVATE_KEY=
APPLE_ROOT_CA_PATHS=/absolute/path/to/AppleRootCA-G3.cer,/absolute/path/to/AppleRootCA-G2.cer
APPLE_ENABLE_ONLINE_CHECKS=true
APPLE_SUBSCRIPTION_PRODUCTS=[{"productId":"genie.premium.monthly","planKey":"genie_premium","featureKeys":["genie.chat"]}]
RESEND_API_KEY=
RESEND_FROM_EMAIL=auth@example.com
RESEND_FROM_NAME=Tricky Genie
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ID=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://tricky-genie.app
OPENROUTER_APP_NAME=Tricky Genie
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
SESSION_SECRET=change-me-to-a-long-random-secret-with-at-least-32-characters
SESSION_ISSUER=tricky-genie
SESSION_COOKIE_NAME=tricky_genie_session
SESSION_COOKIE_SAME_SITE=lax
SESSION_TTL_SECONDS=604800

# App security
# Use an exact comma-separated allowlist of browser origins. Wildcards are not supported.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TRUST_PROXY_HEADERS=false
MAX_REQUEST_BODY_SIZE_BYTES=65536

# Rate limiting
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_AUTH_EMAIL_PER_MINUTE=5
RATE_LIMIT_ACCOUNT_PER_MINUTE=60
